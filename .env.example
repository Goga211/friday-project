# Скопируй в .env и поправь под себя. Префикс FRIDAY_ обязателен
# (кроме ANTHROPIC_API_KEY — это стандарт SDK).

# Мозг (Claude). Без ключа Core работает, но отвечает «мозг недоступен».
# ANTHROPIC_API_KEY=sk-ant-...

# Брокер MQTT
FRIDAY_BROKER_HOST=localhost
FRIDAY_BROKER_PORT=1883

# TLS/mTLS (для dev по умолчанию выключено). При TLS обычно порт 8883.
FRIDAY_TLS=false
# FRIDAY_TLS_CA=infra/certs/ca.crt
# FRIDAY_TLS_CERT=infra/certs/client.crt
# FRIDAY_TLS_KEY=infra/certs/client.key

# --- Устройство (для агента) ---
# Идентификатор. Если пусто — берётся desktop-<hostname>.
# FRIDAY_DEVICE_ID=
# Человеческое имя для команд вида «открой на ноутбуке» («пк», «ноутбук», …).
# FRIDAY_DEVICE_ALIAS=
# MAC для Wake-on-LAN. Пусто — автодетект; задать, если детект ошибается.
# FRIDAY_DEVICE_MAC=

# Wake-on-LAN (Core): куда слать магический пакет.
# FRIDAY_WOL_BROADCAST=255.255.255.255
# FRIDAY_WOL_PORT=9

# Интервал ping от Core к агентам, сек
FRIDAY_PING_INTERVAL=15

# --- HUD (веб-чат + REST API для iPhone, см. docs/iphone-shortcuts.md) ---
# FRIDAY_HUD_HOST=127.0.0.1     # 0.0.0.0 — чтобы ходить с телефона через Tailscale
# FRIDAY_HUD_PORT=8010
# Bearer-токен REST API (/api/*). Не задан → API отключён.
# FRIDAY_HUD_TOKEN=

# Push на телефон через ntfy: полный URL приватного топика. Не задан → notify_phone выключен.
# FRIDAY_PUSH_URL=https://ntfy.sh/friday-<длинный-секрет>

# --- Умный дом (Phase 4, префикс FRIDAY_HOME_) ---
# Контроллер: mock (по умолчанию, без железа) | ha (Home Assistant)
# FRIDAY_HOME_CONTROLLER=mock
# Home Assistant: URL и long-lived token (профиль HA → Security → Long-lived access tokens)
# FRIDAY_HOME_HA_URL=http://homeassistant.local:8123
# FRIDAY_HOME_HA_TOKEN=

# --- Голосовой агент (Phase 2, префикс FRIDAY_VOICE_) ---
# Выбор реализаций. Fake — обкатка без микрофона/облака.
# FRIDAY_VOICE_AUDIO=sounddevice
# WAKE: openwakeword | pushtotalk (Enter вместо слова — быстрый живой тест) | fake
# FRIDAY_VOICE_WAKE=openwakeword
# FRIDAY_VOICE_STT=yandex
# TTS: yandex_v3 (текущий, живые голоса) | yandex (REST v1) | piper (локальный fallback)
# FRIDAY_VOICE_TTS=yandex_v3
# FRIDAY_VOICE_TTS_VOLUME=0.45

# Wake-word: путь к обученной модели «Пятница» (.onnx). Без неё грузятся
# предобученные (НЕ «Пятница»). Порог срабатывания 0..1.
# FRIDAY_VOICE_WAKE_MODEL=models/friday.onnx
# FRIDAY_VOICE_WAKE_THRESHOLD=0.5

# Yandex SpeechKit (STT + TTS). Ключ и folder — из Yandex Cloud.
# FRIDAY_VOICE_YANDEX_API_KEY=
# FRIDAY_VOICE_YANDEX_FOLDER_ID=
# FRIDAY_VOICE_YANDEX_LANG=ru-RU
# FRIDAY_VOICE_YANDEX_TTS_VOICE=alena

# Piper (TTS-fallback): бинарь и русский голос .onnx (см. README).
# FRIDAY_VOICE_PIPER_BIN=piper
# FRIDAY_VOICE_PIPER_MODEL=models/ru_RU-voice.onnx
# FRIDAY_VOICE_PIPER_SAMPLE_RATE=22050

# Аудио-устройства (имя-подстрока или индекс; пусто — системные по умолчанию).
# FRIDAY_VOICE_INPUT_DEVICE=
# FRIDAY_VOICE_OUTPUT_DEVICE=
