# Скопируй в .env и поправь под себя. Префикс CHRISTOPHER_ обязателен.

# Брокер MQTT
CHRISTOPHER_BROKER_HOST=localhost
CHRISTOPHER_BROKER_PORT=1883

# TLS/mTLS (для dev по умолчанию выключено). При TLS обычно порт 8883.
CHRISTOPHER_TLS=false
# CHRISTOPHER_TLS_CA=infra/certs/ca.crt
# CHRISTOPHER_TLS_CERT=infra/certs/client.crt
# CHRISTOPHER_TLS_KEY=infra/certs/client.key

# Идентификатор устройства (для агента). Если пусто — берётся desktop-<hostname>.
# CHRISTOPHER_DEVICE_ID=

# Интервал ping от Core к агентам, сек
CHRISTOPHER_PING_INTERVAL=15

# --- Голосовой агент (Phase 2, префикс CHRISTOPHER_VOICE_) ---
# Выбор реализаций (real | fake). Fake — обкатка без микрофона/облака.
# CHRISTOPHER_VOICE_AUDIO=sounddevice
# CHRISTOPHER_VOICE_WAKE=openwakeword
# CHRISTOPHER_VOICE_STT=yandex
# CHRISTOPHER_VOICE_TTS=piper

# Wake-word: путь к обученной модели «Кристофер» (.onnx/.tflite). Без неё грузятся
# предобученные (НЕ «Кристофер»). Порог срабатывания 0..1.
# CHRISTOPHER_VOICE_WAKE_MODEL=models/christopher.onnx
# CHRISTOPHER_VOICE_WAKE_THRESHOLD=0.5

# Yandex SpeechKit (STT). Ключ и folder — из Yandex Cloud.
# CHRISTOPHER_VOICE_YANDEX_API_KEY=
# CHRISTOPHER_VOICE_YANDEX_FOLDER_ID=
# CHRISTOPHER_VOICE_YANDEX_LANG=ru-RU

# Piper (TTS): бинарь и русский голос .onnx (см. README).
# CHRISTOPHER_VOICE_PIPER_BIN=piper
# CHRISTOPHER_VOICE_PIPER_MODEL=models/ru_RU-voice.onnx
# CHRISTOPHER_VOICE_PIPER_SAMPLE_RATE=22050

# Аудио-устройства (имя-подстрока или индекс; пусто — системные по умолчанию).
# CHRISTOPHER_VOICE_INPUT_DEVICE=
# CHRISTOPHER_VOICE_OUTPUT_DEVICE=
