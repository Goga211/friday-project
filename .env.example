# Скопируй в .env и поправь под себя. Префикс CHRISTOPHER_ обязателен.

# Брокер MQTT
CHRISTOPHER_BROKER_HOST=localhost
CHRISTOPHER_BROKER_PORT=1883

# TLS/mTLS (для dev по умолчанию выключено). При TLS обычно порт 8883.
CHRISTOPHER_TLS=false
# CHRISTOPHER_TLS_CA=infra/certs/ca.crt
# CHRISTOPHER_TLS_CERT=infra/certs/client.crt
# CHRISTOPHER_TLS_KEY=infra/certs/client.key

# Идентификатор устройства (для агента). Если пусто — берётся desktop-<hostname>.
# CHRISTOPHER_DEVICE_ID=

# Интервал ping от Core к агентам, сек
CHRISTOPHER_PING_INTERVAL=15
